rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helpers
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isAdmin() { return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Users Collection
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'email', 'role']) &&
               data.uid == request.auth.uid &&
               data.email is string &&
               data.role in ['locataire', 'proprietaire', 'admin'];
      }
      
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isSignedIn() && isValidUser(incoming());
      allow update: if isOwner(userId) && incoming().role == existing().role;
    }

    // Properties Collection
    match /properties/{propertyId} {
      function isValidProperty(data) {
        return data.keys().hasAll(['title', 'ownerId', 'status']) &&
               data.title is string && data.title.size() <= 200 &&
               isValidId(data.ownerId);
      }

      allow read: if true; // Public listings
      allow create: if isSignedIn() && isValidProperty(incoming()) && (incoming().ownerId == request.auth.uid || isAdmin());
      allow update: if isSignedIn() && isValidProperty(incoming()) && 
                    (existing().ownerId == request.auth.uid || isAdmin()) &&
                    incoming().ownerId == existing().ownerId;
      allow delete: if isAdmin() || (isSignedIn() && existing().ownerId == request.auth.uid);
    }

    // Contracts Collection
    match /contracts/{contractId} {
      allow read: if isSignedIn() && (resource.data.tenantId == request.auth.uid || resource.data.ownerId == request.auth.uid || isAdmin());
      allow create: if isAdmin(); // Only admins/system can create contracts
      allow update: if isAdmin();
    }

    // Payments Collection
    match /payments/{paymentId} {
      allow read: if isSignedIn() && (resource.data.tenantId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().tenantId == request.auth.uid;
      allow update: if isAdmin();
    }

    // Interventions
    match /interventions/{intId} {
      allow read: if isSignedIn() && (resource.data.requesterId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().requesterId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.requesterId == request.auth.uid || isAdmin());
    }

    // Quotes
    match /quotes/{quoteId} {
      allow create: if true; // Public can request quotes
      allow read, update: if isAdmin();
    }
  }
}
